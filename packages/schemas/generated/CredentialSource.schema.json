{
  "$id": "https://jefahnierocks.local/host-capability-substrate/schemas/CredentialSource.schema.json",
  "title": "CredentialSource",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0",
      "description": "Entity schema version for the first Phase 1 Ring 0 schema slice."
    },
    "credential_source_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "description": "Stable local entity identifier. It is not a secret value."
    },
    "source_type": {
      "type": "string",
      "enum": [
        "macos_keychain",
        "codex_home_file",
        "claude_credentials_file",
        "oauth_device_flow",
        "subscription_oauth",
        "api_key_env",
        "api_key_helper",
        "onepassword",
        "infisical",
        "vault",
        "devenv_secretspec",
        "long_lived_setup_token",
        "service_account",
        "brokered_secret_reference"
      ],
      "description": "Durable credential source class from ADR 0018."
    },
    "owning_surface": {
      "type": "string",
      "enum": [
        "codex_cli",
        "codex_app_sandboxed",
        "codex_ide_ext",
        "claude_code_cli",
        "claude_desktop",
        "claude_code_ide_ext",
        "zed_external_agent",
        "warp_terminal",
        "mcp_server",
        "setup_script",
        "app_integrated_terminal",
        "unknown"
      ],
      "description": "Agent or host surface that owns this execution context."
    },
    "storage_plane": {
      "type": "string",
      "enum": [
        "macos_keychain",
        "user_config_file",
        "shell_env",
        "broker",
        "provider_control_plane",
        "external_secret_store",
        "unknown"
      ],
      "description": "Where credential authority is durably stored."
    },
    "durability": {
      "type": "string",
      "enum": [
        "process",
        "session",
        "long_lived",
        "rotating",
        "one_time_capture",
        "unknown"
      ],
      "description": "Expected lifetime class for a credential source."
    },
    "scope": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "string",
          "minLength": 1
        },
        "capabilities": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "provider",
        "capabilities"
      ],
      "additionalProperties": false,
      "description": "Provider scope and audience metadata for a credential source."
    },
    "secret_ref": {
      "description": "Opaque reference only, such as op:// or hcs://. Never raw secret material.",
      "type": "string",
      "minLength": 1
    },
    "env_var_name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
      "description": "Environment variable name only. The schema intentionally has no value field."
    },
    "expires_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
          "description": "RFC 3339 timestamp with an explicit UTC offset."
        },
        {
          "type": "null"
        }
      ]
    },
    "rotation": {
      "type": "object",
      "properties": {
        "expected": {
          "type": "boolean"
        },
        "last_rotated_at": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time",
              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
              "description": "RFC 3339 timestamp with an explicit UTC offset."
            },
            {
              "type": "null"
            }
          ]
        },
        "rotate_by": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time",
              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
              "description": "RFC 3339 timestamp with an explicit UTC offset."
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "expected"
      ],
      "additionalProperties": false,
      "description": "Rotation expectation and timestamps for the credential source."
    },
    "health": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "healthy",
            "failing",
            "expired",
            "pending_verification",
            "unknown"
          ],
          "description": "Healthcheck status without exposing credential material."
        },
        "checked_at": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time",
              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
              "description": "RFC 3339 timestamp with an explicit UTC offset."
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "status"
      ],
      "additionalProperties": false,
      "description": "Last healthcheck status for a credential source."
    },
    "evidence_refs": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "evidence_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "description": "Reference to an Evidence record or fixture."
          },
          "source": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable source name or artifact path."
          },
          "observed_at": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
            "description": "RFC 3339 timestamp with an explicit UTC offset."
          },
          "valid_until": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
                "description": "RFC 3339 timestamp with an explicit UTC offset."
              },
              {
                "type": "null"
              }
            ]
          },
          "authority": {
            "type": "string",
            "enum": [
              "project-local",
              "workspace-local",
              "user-global",
              "system",
              "derived",
              "sandbox-observation",
              "host-observation",
              "vendor-doc",
              "installed-runtime",
              "human-observed"
            ],
            "description": "Authority plane for a fact or observation."
          },
          "parser_version": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "string",
            "enum": [
              "authoritative",
              "high",
              "best-effort",
              "stale",
              "unknown"
            ],
            "description": "Confidence assigned to an observation by the producer."
          }
        },
        "required": [
          "evidence_id",
          "source",
          "observed_at",
          "authority",
          "confidence"
        ],
        "additionalProperties": false,
        "description": "Small provenance reference embedded until the full Evidence entity lands."
      }
    }
  },
  "required": [
    "schema_version",
    "credential_source_id",
    "source_type",
    "storage_plane",
    "durability",
    "scope",
    "rotation",
    "health",
    "evidence_refs"
  ],
  "additionalProperties": false,
  "description": "Ring 0 credential source entity from ADR 0018."
}
