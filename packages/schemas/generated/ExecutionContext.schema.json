{
  "$id": "https://jefahnierocks.local/host-capability-substrate/schemas/ExecutionContext.schema.json",
  "title": "ExecutionContext",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0",
      "description": "Entity schema version for the first Phase 1 Ring 0 schema slice."
    },
    "execution_context_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "description": "Stable local entity identifier. It is not a secret value."
    },
    "surface": {
      "type": "string",
      "enum": [
        "codex_cli",
        "codex_app_sandboxed",
        "codex_ide_ext",
        "claude_code_cli",
        "claude_desktop",
        "claude_code_ide_ext",
        "zed_external_agent",
        "warp_terminal",
        "mcp_server",
        "setup_script",
        "app_integrated_terminal",
        "unknown"
      ],
      "description": "Agent or host surface that owns this execution context."
    },
    "kind": {
      "type": "string",
      "enum": [
        "cli",
        "gui_app",
        "ide_extension",
        "terminal",
        "mcp_server",
        "setup_script",
        "subagent",
        "background_worker",
        "unknown"
      ],
      "description": "General execution-context family."
    },
    "phase": {
      "type": "string",
      "enum": [
        "boot",
        "launchd_user_session",
        "gui_app_exec",
        "terminal_emulator_launch",
        "shell_login_init",
        "shell_interactive_init",
        "direnv_chpwd",
        "mise_activate",
        "agent_launch",
        "agent_env_policy_apply",
        "agent_session_hook",
        "mcp_server_init",
        "subagent_spawn",
        "tool_call_subprocess"
      ],
      "description": "Ordered startup phase from ADR 0016 shell/environment synthesis."
    },
    "host_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "description": "Stable local entity identifier. It is not a secret value."
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "description": "Stable local entity identifier. It is not a secret value."
    },
    "agent_client_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "description": "Stable local entity identifier. It is not a secret value."
    },
    "shell": {
      "type": "object",
      "properties": {
        "carrier": {
          "type": "string",
          "enum": [
            "none",
            "argv_exec",
            "shell_command",
            "mcp_stdio",
            "mcp_http",
            "app_rpc",
            "ide_task",
            "integrated_terminal",
            "unknown"
          ],
          "description": "Mechanism carrying work into the process."
        },
        "shell_path": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "argv_flags": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "login_observed": {
          "type": "string",
          "enum": [
            "observed_present",
            "observed_absent",
            "pending",
            "unknown",
            "not_applicable"
          ],
          "description": "Status for a per-surface capability or inheritance observation."
        },
        "interactive_observed": {
          "type": "string",
          "enum": [
            "observed_present",
            "observed_absent",
            "pending",
            "unknown",
            "not_applicable"
          ],
          "description": "Status for a per-surface capability or inheritance observation."
        },
        "startup_files_observed": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "none",
              "etc_profile",
              "etc_zprofile",
              "etc_zshenv",
              "etc_zshrc",
              "user_profile",
              "user_bash_profile",
              "user_bashrc",
              "user_zprofile",
              "user_zshenv",
              "user_zshrc",
              "direnv_envrc",
              "mise_config",
              "unknown"
            ],
            "description": "Startup file observed or declared for a shell phase."
          }
        },
        "marker_env_visible": {
          "type": "string",
          "enum": [
            "observed_present",
            "observed_absent",
            "pending",
            "unknown",
            "not_applicable"
          ],
          "description": "Status for a per-surface capability or inheritance observation."
        }
      },
      "required": [
        "carrier",
        "shell_path",
        "argv_flags",
        "login_observed",
        "interactive_observed",
        "startup_files_observed",
        "marker_env_visible"
      ],
      "additionalProperties": false,
      "description": "Shell carrier facts for a specific surface and startup phase."
    },
    "sandbox": {
      "type": "object",
      "properties": {
        "profile": {
          "type": "string",
          "enum": [
            "none",
            "seatbelt",
            "sandbox_exec",
            "workspace_write",
            "read_only",
            "full_access",
            "ide_host",
            "unknown"
          ],
          "description": "Coarse sandbox profile for the execution context."
        },
        "filesystem": {
          "type": "string",
          "enum": [
            "observed_allowed",
            "observed_denied",
            "pending",
            "unknown",
            "not_applicable"
          ],
          "description": "Capability status for the named execution-context surface."
        },
        "network": {
          "type": "string",
          "enum": [
            "observed_allowed",
            "observed_denied",
            "pending",
            "unknown",
            "not_applicable"
          ],
          "description": "Capability status for the named execution-context surface."
        },
        "keychain": {
          "type": "string",
          "enum": [
            "observed_allowed",
            "observed_denied",
            "pending",
            "unknown",
            "not_applicable"
          ],
          "description": "Capability status for the named execution-context surface."
        }
      },
      "required": [
        "profile",
        "filesystem",
        "network",
        "keychain"
      ],
      "additionalProperties": false,
      "description": "Sandbox and app-internal capability matrix for an execution context."
    },
    "env_inheritance": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "launchd_user_session_only",
            "process_spawn",
            "codex_shell_environment_policy",
            "claude_settings_env",
            "terminal_shell",
            "direnv_mise",
            "unknown"
          ],
          "description": "Declared or observed environment inheritance mode."
        },
        "terminal_shell_inherited": {
          "type": "string",
          "enum": [
            "observed_present",
            "observed_absent",
            "pending",
            "unknown",
            "not_applicable"
          ],
          "description": "Status for a per-surface capability or inheritance observation."
        },
        "operator_policy": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "inherit",
                "include_only",
                "exclude",
                "set",
                "overrides",
                "ignore_default_excludes"
              ],
              "description": "Codex shell_environment_policy vocabulary adopted by ADR 0016."
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "mode",
        "terminal_shell_inherited"
      ],
      "additionalProperties": false,
      "description": "How environment variables reach, or do not reach, this context."
    },
    "open_questions": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "evidence_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "description": "Reference to an Evidence record or fixture."
          },
          "source": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable source name or artifact path."
          },
          "observed_at": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
            "description": "RFC 3339 timestamp with an explicit UTC offset."
          },
          "valid_until": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
                "description": "RFC 3339 timestamp with an explicit UTC offset."
              },
              {
                "type": "null"
              }
            ]
          },
          "authority": {
            "type": "string",
            "enum": [
              "project-local",
              "workspace-local",
              "user-global",
              "system",
              "derived",
              "sandbox-observation",
              "host-observation",
              "vendor-doc",
              "installed-runtime",
              "human-observed"
            ],
            "description": "Authority plane for a fact or observation."
          },
          "parser_version": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "string",
            "enum": [
              "authoritative",
              "high",
              "best-effort",
              "stale",
              "unknown"
            ],
            "description": "Confidence assigned to an observation by the producer."
          }
        },
        "required": [
          "evidence_id",
          "source",
          "observed_at",
          "authority",
          "confidence"
        ],
        "additionalProperties": false,
        "description": "Lightweight reference or embedded provenance preview for an Evidence record. Not a substitute for the full Evidence entity."
      }
    }
  },
  "required": [
    "schema_version",
    "execution_context_id",
    "surface",
    "kind",
    "phase",
    "shell",
    "sandbox",
    "env_inheritance",
    "open_questions",
    "evidence_refs"
  ],
  "additionalProperties": false,
  "description": "Ring 0 execution-context entity from ADR 0016 and ADR 0017."
}
