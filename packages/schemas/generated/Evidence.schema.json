{
  "$id": "https://jefahnierocks.local/host-capability-substrate/schemas/Evidence.schema.json",
  "title": "Evidence",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1.0",
          "description": "Entity schema version for the first Phase 1 Ring 0 schema slice."
        },
        "evidence_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "description": "Stable local entity identifier. It is not a secret value."
        },
        "evidence_kind": {
          "type": "string",
          "enum": [
            "observation",
            "receipt",
            "derived",
            "human_decision",
            "fixture"
          ],
          "description": "Evidence record family from ADR 0023."
        },
        "subject_refs": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "subject_kind": {
                "type": "string",
                "enum": [
                  "host",
                  "workspace",
                  "principal",
                  "agent_client",
                  "session",
                  "tool_provider",
                  "tool_installation",
                  "resolved_tool",
                  "capability",
                  "operation_shape",
                  "command_shape",
                  "evidence",
                  "policy_rule",
                  "decision",
                  "approval_grant",
                  "run",
                  "artifact",
                  "lease",
                  "lock",
                  "secret_reference",
                  "resource_budget",
                  "execution_context",
                  "credential_source",
                  "startup_phase",
                  "provider_object",
                  "external_control_plane",
                  "git_repository",
                  "git_ref",
                  "github_check",
                  "filesystem_path",
                  "process",
                  "unknown"
                ],
                "description": "Kind of subject the evidence is about."
              },
              "subject_id": {
                "type": "string",
                "minLength": 1
              },
              "relation": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "subject_kind",
              "subject_id"
            ],
            "additionalProperties": false,
            "description": "Reference to the subject described by an Evidence record."
          }
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
          "description": "RFC 3339 timestamp with an explicit UTC offset."
        },
        "valid_until": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time",
              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
              "description": "RFC 3339 timestamp with an explicit UTC offset."
            },
            {
              "type": "null"
            }
          ]
        },
        "authority": {
          "type": "string",
          "enum": [
            "project-local",
            "workspace-local",
            "user-global",
            "system",
            "derived",
            "host-observation",
            "vendor-doc",
            "installed-runtime",
            "human-observed"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "authoritative",
            "high",
            "best-effort",
            "stale",
            "unknown"
          ],
          "description": "Confidence assigned to an observation by the producer."
        },
        "parser_version": {
          "type": "string",
          "minLength": 1
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "host_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "description": "Stable local entity identifier. It is not a secret value."
        },
        "workspace_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "description": "Stable local entity identifier. It is not a secret value."
        },
        "execution_context_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "description": "Stable local entity identifier. It is not a secret value."
        },
        "session_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "description": "Stable local entity identifier. It is not a secret value."
        },
        "run_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "description": "Stable local entity identifier. It is not a secret value."
        },
        "payload_schema_version": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/__schema0"
        },
        "redaction_mode": {
          "type": "string",
          "enum": [
            "none",
            "redacted",
            "classified",
            "hash_only",
            "reference_only",
            "mixed"
          ],
          "description": "How sensitive payload material was handled before persistence."
        }
      },
      "required": [
        "schema_version",
        "evidence_id",
        "evidence_kind",
        "subject_refs",
        "source",
        "observed_at",
        "valid_until",
        "authority",
        "confidence",
        "parser_version"
      ],
      "additionalProperties": false
    },
