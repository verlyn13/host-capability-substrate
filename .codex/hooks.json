{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.codex/hooks/hcs-hook\" pre-bash",
            "timeout": 5,
            "statusMessage": "Checking HCS guardrails"
          }
        ]
      }
    ]
  }
}
